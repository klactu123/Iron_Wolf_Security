# GroundTruth Homestead — local configuration
#
# Copy this file to `.env.local` and edit. `.env.local` is gitignored.
# Restart `npm run dev` after editing.

# --- AI provider ---------------------------------------------------------
#
# `mock` (default): works with no key. Calculator-aware placeholder text.
# `claude`: real Anthropic API. Bring your own key.
# `openai`: stub only in this build.
HOMESTEAD_AI_PROVIDER=mock

# --- Claude (only used when HOMESTEAD_AI_PROVIDER=claude) ----------------
#
# Get a key at https://console.anthropic.com/settings/keys
# The key is read from this file on server startup and used only to call
# api.anthropic.com. It never leaves your machine otherwise.
ANTHROPIC_API_KEY=

# Optional model override. Defaults to claude-opus-4-7.
# Cheaper alternatives:
#   claude-sonnet-4-6   — fast, strong reasoning, ~5x cheaper than Opus
#   claude-haiku-4-5    — fastest, cheapest, fine for short explanations
# ANTHROPIC_MODEL=claude-opus-4-7

# --- OpenAI (stub — not implemented in this build) -----------------------
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Storage -------------------------------------------------------------
#
# JSON store path. Defaults to ./data/store.json.
# HOMESTEAD_STORE_PATH=
